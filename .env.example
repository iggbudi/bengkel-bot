# ============================================
# BengkelBot — Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# --- LLM Provider ---
# openai = OpenAI API (default) | sumopod = MiniMax via SumoPod
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-mini

# --- OpenAI ---
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# --- SumoPod / MiniMax LLM (if LLM_PROVIDER=sumopod) ---
# Get your API key from https://sumopod.com
SUMOPOD_API_KEY=your_sumopod_api_key_here
SUMOPOD_BASE_URL=https://open.sumopod.com/v1

# --- WhatsApp (Baileys) ---
# Your personal WhatsApp number or a dedicated number for the bot
# Baileys uses QR code auth — session is stored in ./auth/wa-session
WHATSAPP_SESSION_MODE=local        # 'local' = QR scan, 'paired' = use existing session
WHATSAPP_PHONE_NUMBER=             # Optional: link to a specific number

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=

# --- Workshop Config ---
WORKSHOP_NAME=BengkelBot Demo
WORKSHOP_ADDRESS=Jl. Raya Tembalang No.1, Semarang
WORKSHOP_PHONE=081234567890
WORKSHOP_HOURS=08.00-17.00
WORKSHOP_DAYS=Senin-Sabtu
WORKSHOP_SPECIALIZATION=Mobil umum (Honda, Toyota, Suzuki, Daihatsu)

# --- Bot Behaviour ---
BOT_NAME=BengkelBot
BOT_LANGUAGE=id                     # id = Indonesian (with Javanese slang)
LOG_LEVEL=info
